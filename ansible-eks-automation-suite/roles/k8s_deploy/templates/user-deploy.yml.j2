apiVersion: apps/v1
kind: Deployment
metadata:
  name: user-service
  namespace: {{ micro_namespace }}
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
      app: user-service
  template:
    metadata:
      labels:
        app: user-service
    spec:
      containers:
        - name: user-service
          image: {{ user_service_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ user_service_port }}
          livenessProbe:
            httpGet:
              path: /healthz
              port: {{ user_service_port }}
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /readyz
              port: {{ user_service_port }}
            initialDelaySeconds: 3
            periodSeconds: 10
