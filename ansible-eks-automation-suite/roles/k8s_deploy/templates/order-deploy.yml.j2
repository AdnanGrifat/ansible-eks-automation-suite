apiVersion: apps/v1
kind: Deployment
metadata:
  name: order-service
  namespace: {{ micro_namespace }}
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
      app: order-service
  template:
    metadata:
      labels:
        app: order-service
    spec:
      containers:
        - name: order-service
          image: {{ order_service_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ order_service_port }}
          livenessProbe:
            httpGet:
              path: /healthz
              port: {{ order_service_port }}
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /readyz
              port: {{ order_service_port }}
            initialDelaySeconds: 3
            periodSeconds: 10
